# Servidor
PORT=3000
# Nivel de log de pino: trace|debug|info|warn|error|fatal|silent (def. info)
LOG_LEVEL=info

# Orígenes permitidos para CORS (separados por coma). OBLIGATORIO en todos los
# modos (fail-closed); en desarrollo local usa http://localhost:3000
CORS_ORIGIN=https://task-to-do.app,https://www.task-to-do.app

# Límites de la API pública (opcionales, estos son los defaults)
# Escrituras (POST/PUT/DELETE) por IP por minuto
WRITE_RATE_LIMIT=20
# Tope total de tareas: los POST devuelven 429 al alcanzarlo
MAX_TASKS=1000

# Base de datos
DB_HOST=db
DB_PORT=5432
DB_NAME=tasksdb
DB_USER=taskuser
DB_PASSWORD=