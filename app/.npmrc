# Configuración de seguridad respetada por pnpm 11.
# Protege contra ataques de cadena de suministro (supply chain attacks).

# Bloquear scripts preinstall/install/postinstall de dependencias.
# Mitiga ataques tipo TanStack (noviembre 2026), Axios (marzo 2026)
# y Mini Shai-Hulud (abril 2026) que se propagan vía estos scripts.
# En pnpm 11, además, los builds están bloqueados por defecto y deben
# aprobarse explícitamente con `pnpm approve-builds`.
ignore-scripts=true

# Fijar versiones exactas al instalar paquetes nuevos.
save-exact=true

# Nota: pnpm 11 ya trae `minimumReleaseAge` en 1440 minutos por defecto,
# así que las versiones recién publicadas se ignoran durante 24h.
# No definir `minimum-release-age=0` o `minimumReleaseAge: 0` en ningún
# pnpm-workspace.yaml, eso desactivaría la defensa.
