# Configuración de seguridad para npm
# Protege contra ataques de cadena de suministro (supply chain attacks)

# No ejecutar scripts automáticamente al instalar paquetes.
# Mitiga ataques tipo Axios (marzo 2026) y Mini Shai-Hulud (abril 2026)
# que se propagaban via scripts postinstall.
ignore-scripts=true

# Solo instalar paquetes publicados hace al menos 7 días.
# Da tiempo a que la comunidad detecte versiones maliciosas
# antes de que entren a tu proyecto.
min-release-age=7

# Fijar versiones exactas al instalar paquetes
save-exact=true